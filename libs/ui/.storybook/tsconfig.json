{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noUnusedLocals": false
  },
  "exclude": ["../**/*.spec.ts"],
  "include": [
    "../src/**/*.stories.ts",
    "../src/**/*.stories.js",
    "../src/**/*.stories.jsx",
    "../src/**/*.stories.tsx",
    "../src/**/*.stories.mdx"
  ],
  "files": [
    "main.ts",
    "preview.ts"
  ]
}
